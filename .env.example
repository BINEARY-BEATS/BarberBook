# Firebase Configuration
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_MOBILESDK_APP_ID=YOUR_MOBILESDK_APP_ID

# Google Maps API
MAPS_API_KEY=YOUR_MAPS_API_KEY

# Android Configuration
ANDROID_SDK_PATH=/path/to/android/sdk
FLUTTER_SDK_PATH=/path/to/flutter
FLUTTER_BUILD_MODE=debug
FLUTTER_VERSION_NAME=1.0.0
FLUTTER_VERSION_CODE=1

# App Configuration
PACKAGE_NAME=com.barberbook.app
DEBUG_MODE=false

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual values from Firebase Console
# 3. Never commit .env file to version control
